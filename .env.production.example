APP_NAME=AI Document Intelligence Platform
LOG_LEVEL=INFO
JSON_LOGS=true

POSTGRES_DB=docintel
POSTGRES_USER=docintel
POSTGRES_PASSWORD=change-me-long-random-password
DATABASE_URL=postgresql+psycopg://docintel:change-me-long-random-password@postgres:5432/docintel
REDIS_URL=redis://redis:6379/0

SECRET_KEY=change-me-64-plus-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
FRONTEND_ORIGIN=https://docs.example.com
NEXT_PUBLIC_API_URL=https://docs.example.com/api/v1

MAX_UPLOAD_MB=50
DEFAULT_RETENTION_DAYS=0
STORAGE_PROVIDER=local

AI_PROVIDER=fallback
AI_REQUEST_TIMEOUT_SECONDS=90
AI_MAX_CONTEXT_CHARS=18000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
ALLOW_EXTERNAL_AI_WITH_PII=false
REDACT_PII_FOR_EXTERNAL_AI=true

EMAIL_PROVIDER=outbox
EMAIL_FROM=DocIntel <no-reply@example.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

ADMIN_EMAILS=admin@example.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
