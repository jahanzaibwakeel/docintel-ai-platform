SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_EXPIRE_MINUTES=30
PASSWORD_RESET_RETURN_TOKEN=true
WORKSPACE_INVITE_EXPIRE_DAYS=14
EMAIL_PROVIDER=outbox
EMAIL_FROM=DocIntel <no-reply@docintel.local>
EMAIL_OUTBOX_DIR=email-outbox
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
ADMIN_EMAILS=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
LOG_LEVEL=INFO
JSON_LOGS=true
DEFAULT_RETENTION_DAYS=0
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_ENDPOINT_URL=
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PRESIGN_SECONDS=300
MAX_UPLOAD_MB=25
ALLOW_EXTERNAL_AI_WITH_PII=false
REDACT_PII_FOR_EXTERNAL_AI=true
AI_PROVIDER=fallback
AI_REQUEST_TIMEOUT_SECONDS=90
AI_MAX_CONTEXT_CHARS=18000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
ENABLE_OCR=true
OCR_MIN_CHARS_PER_PAGE=40
OCR_DPI=220
